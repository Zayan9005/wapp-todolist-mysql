@page
@model wapp.Pages.ProfileModel
@{
    ViewData["Title"] = "Digital Identity";
    Layout = null;
}
<!DOCTYPE html>
<html>
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="stylesheet" href="~/css/site.css" />
    <style>
        :root {
            --accent: #00d2ff;
            --purple: #9d50bb;
            --glass: rgba(255, 255, 255, 0.05);
        }

        body {
            background: #0f0c29;
            background: radial-gradient(circle at top right, #1e2a4a, #0f0c29);
            min-height: 100vh;
            display: flex;
            flex-direction: column;
            overflow-x: hidden;
        }

        .profile-container {
            max-width: 900px;
            margin: 50px auto;
            display: grid;
            grid-template-columns: 300px 1fr;
            gap: 30px;
            padding: 20px;
        }

        /* Avatar Section */
        .avatar-card {
            background: var(--glass);
            backdrop-filter: blur(15px);
            border: 1px solid rgba(255, 255, 255, 0.1);
            border-radius: 30px;
            padding: 40px 20px;
            text-align: center;
            box-shadow: 0 20px 40px rgba(0,0,0,0.4);
        }

        .profile-pic-container {
            position: relative;
            width: 180px;
            height: 180px;
            margin: 0 auto 20px;
        }

        #profileImage {
            width: 100%;
            height: 100%;
            border-radius: 50%;
            object-fit: cover;
            border: 4px solid var(--accent);
            box-shadow: 0 0 20px rgba(0, 210, 255, 0.3);
            transition: 0.3s;
        }

        .upload-btn {
            position: absolute;
            bottom: 5px;
            right: 5px;
            background: var(--accent);
            color: black;
            width: 40px;
            height: 40px;
            border-radius: 50%;
            display: flex;
            align-items: center;
            justify-content: center;
            cursor: pointer;
            font-size: 20px;
            border: 3px solid #0f0c29;
        }

        /* Content Section */
        .content-card {
            background: var(--glass);
            backdrop-filter: blur(15px);
            border: 1px solid rgba(255, 255, 255, 0.1);
            border-radius: 30px;
            padding: 40px;
        }

        .input-group {
            margin-bottom: 25px;
        }

        .input-group label {
            display: block;
            color: var(--accent);
            text-transform: uppercase;
            font-size: 0.75rem;
            letter-spacing: 2px;
            margin-bottom: 8px;
        }

        .live-input {
            width: 100%;
            background: rgba(255,255,255,0.03);
            border: 1px solid rgba(255,255,255,0.1);
            padding: 12px;
            border-radius: 10px;
            color: white;
            font-size: 1.1rem;
            transition: 0.3s;
        }

        .live-input:focus {
            outline: none;
            border-color: var(--accent);
            background: rgba(255,255,255,0.08);
        }

        /* Real-time Animations */
        .fade-in { animation: fadeIn 0.8s ease-out; }
        @@keyframes fadeIn {
            from { opacity: 0; transform: translateY(20px); }
            to { opacity: 1; transform: translateY(0); }
        }
    </style>
</head>
<body>

    <nav class="navbar">
        <a href="/">Home</a>
        <a href="/GradeCalculator">Grades</a>
        <a href="/FeedbackForm">Feedback</a>
        <a href="/Profile">Profile</a>
    </nav>

    <div class="profile-container fade-in">
        <aside class="avatar-card">
            <div class="profile-pic-container">
                <img id="profileImage" src="https://api.dicebear.com/7.x/avataaars/svg?seed=Zayan" alt="Profile">
                <label for="imageUpload" class="upload-btn">📷</label>
                <input type="file" id="imageUpload" hidden accept="image/*">
            </div>
            <h2 id="display-name" style="color: white; margin: 10px 0;">@Model.StudentName</h2>
            <p id="display-tp" style="color: var(--accent); font-family: monospace;">@Model.TPNumber</p>
        </aside>

        <main class="content-card">
            <h2 style="color: white; margin-bottom: 30px;">Profile Settings</h2>
            
            <div class="input-group">
                <label>Display Name</label>
                <input type="text" id="nameInput" class="live-input" value="@Model.StudentName">
            </div>

            <div class="input-group">
                <label>Student ID (TP Number)</label>
                <input type="text" id="tpInput" class="live-input" value="@Model.TPNumber">
            </div>

            <div class="input-group">
                <label>Professional Bio</label>
                <textarea id="bioInput" class="live-input" rows="4">@Model.Bio</textarea>
            </div>

            <div id="status-msg" style="color: #4ade80; font-size: 0.9rem; opacity: 0;">✔ Auto-saved to session</div>
        </main>
    </div>

    <script>
        // Real-time Update Logic
        const nameInput = document.getElementById('nameInput');
        const tpInput = document.getElementById('tpInput');
        const displayName = document.getElementById('display-name');
        const displayTP = document.getElementById('display-tp');
        const statusMsg = document.getElementById('status-msg');

        function triggerSaveEffect() {
            statusMsg.style.opacity = '1';
            setTimeout(() => { statusMsg.style.opacity = '0'; }, 2000);
        }

        nameInput.addEventListener('input', (e) => {
            displayName.innerText = e.target.value || "Your Name";
            triggerSaveEffect();
        });

        tpInput.addEventListener('input', (e) => {
            displayTP.innerText = e.target.value || "TPXXXXXX";
            triggerSaveEffect();
        });

        // Image Upload Logic
        const imageUpload = document.getElementById('imageUpload');
        const profileImage = document.getElementById('profileImage');

        imageUpload.addEventListener('change', function() {
            const file = this.files[0];
            if (file) {
                const reader = new FileReader();
                reader.onload = function(e) {
                    profileImage.src = e.target.result;
                };
                reader.readAsDataURL(file);
            }
        });
    </script>
</body>
</html>