@page
@model wapp.Pages.StudentInfoModel
@{
    ViewData["Title"] = "Digital Student ID";
}

<style>
    .id-container {
        perspective: 1000px;
        margin-top: 50px;
    }

    .id-card {
        background: rgba(255, 255, 255, 0.05);
        backdrop-filter: blur(20px);
        border: 1px solid rgba(0, 210, 255, 0.3);
        border-radius: 25px;
        padding: 40px;
        width: 450px;
        transition: transform 0.6s cubic-bezier(0.4, 0, 0.2, 1), box-shadow 0.3s;
        transform-style: preserve-3d;
        position: relative;
    }

    .id-card:hover {
        transform: rotateY(10deg) rotateX(5deg);
        box-shadow: -20px 20px 50px rgba(0, 0, 0, 0.5), 0 0 20px rgba(0, 210, 255, 0.2);
        border-color: #00d2ff;
    }

    .chip {
        width: 50px;
        height: 40px;
        background: linear-gradient(135deg, #ffd700, #b8860b);
        border-radius: 8px;
        margin-bottom: 20px;
        position: relative;
    }

    .data-row {
        margin-bottom: 15px;
        transition: transform 0.2s;
    }

    .data-row:hover {
        transform: translateX(10px);
    }

    .label {
        font-size: 0.7rem;
        color: #00d2ff;
        text-transform: uppercase;
        letter-spacing: 2px;
        margin: 0;
    }

    .value {
        font-size: 1.1rem;
        font-weight: 600;
        color: white;
        margin: 0;
    }

    .status-indicator {
        display: flex;
        align-items: center;
        gap: 10px;
        font-size: 0.8rem;
        color: #4ade80;
        margin-top: 25px;
    }

    .dot {
        height: 8px;
        width: 8px;
        background-color: #4ade80;
        border-radius: 50%;
        box-shadow: 0 0 10px #4ade80;
        animation: blink 1.5s infinite;
    }

    @@keyframes blink {
        0% { opacity: 1; }
        50% { opacity: 0.3; }
        100% { opacity: 1; }
    }
</style>

<div class="id-container">
    <div class="id-card">
        <div style="display: flex; justify-content: space-between; align-items: flex-start;">
            <div class="chip"></div>
            <img src="https://api.dicebear.com/7.x/bottts/svg?seed=Zayan" style="width: 60px; border-radius: 12px; border: 1px solid rgba(255,255,255,0.2);">
        </div>

        <div class="data-row">
            <p class="label">Student Name</p>
            <p class="value">@Model.Name</p>
        </div>

        <div class="data-row">
            <p class="label">Identification No.</p>
            <p class="value">@Model.StudentID</p>
        </div>

        <div class="data-row">
            <p class="label">Major / Programme</p>
            <p class="value">@Model.Programme</p>
        </div>

        <div style="margin-top: 20px; padding-top: 15px; border-top: 1px solid rgba(255,255,255,0.1);">
            <p style="font-size: 0.7rem; color: rgba(255,255,255,0.4);">Portal Access: @Model.LastLogin</p>
        </div>

        <div class="status-indicator">
            <span class="dot"></span>
            <span>SYSTEM ACTIVE / SESSION SECURED</span>
        </div>
    </div>

    <div style="margin-top: 30px; text-align: center;">
        <a href="/" class="sexy-link" style="padding: 10px 25px; width: auto; display: inline-block;">
            Return to Dashboard
        </a>
    </div>
</div>