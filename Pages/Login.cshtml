@page
@model wapp.Pages.LoginModel
@{
    ViewData["Title"] = "Login";
}

<style>
    .auth-container {
        display: flex;
        justify-content: center;
        align-items: center;
        min-height: 75vh;
    }
    .auth-card {
        background: rgba(255, 255, 255, 0.05);
        backdrop-filter: blur(15px);
        border: 1px solid rgba(255, 255, 255, 0.1);
        padding: 40px;
        border-radius: 30px;
        box-shadow: 0 25px 50px rgba(0,0,0,0.5);
        width: 90%;
        max-width: 420px;
    }
    .auth-title {
        font-weight: 900;
        margin-bottom: 5px;
        background: linear-gradient(to right, #00d2ff, #9d50bb);
        -webkit-background-clip: text;
        -webkit-text-fill-color: transparent;
        text-transform: uppercase;
        letter-spacing: 2px;
    }
    .auth-input-group {
        display: flex;
        flex-direction: column;
        gap: 6px;
        margin-bottom: 20px;
    }
    .auth-label {
        color: rgba(255, 255, 255, 0.7);
        font-size: 0.85rem;
        font-weight: 500;
        letter-spacing: 0.5px;
    }
    .auth-field {
        width: 100%;
        padding: 12px 16px;
        background: rgba(255, 255, 255, 0.03);
        border: 1px solid rgba(255, 255, 255, 0.1);
        border-radius: 12px;
        color: #fff;
        font-size: 0.95rem;
        transition: all 0.3s ease;
    }
    .auth-field:focus {
        outline: none;
        border-color: #9d50bb;
        background: rgba(255, 255, 255, 0.07);
        box-shadow: 0 0 10px rgba(157, 80, 187, 0.2);
    }
    .auth-btn {
        width: 100%;
        padding: 14px;
        background: rgba(255, 255, 255, 0.03);
        border: 1px solid rgba(255, 255, 255, 0.1);
        border-radius: 15px;
        color: #fff;
        font-weight: 600;
        font-size: 1rem;
        cursor: pointer;
        transition: all 0.3s ease;
        margin-top: 5px;
    }
    .auth-btn:hover {
        background: linear-gradient(45deg, #9d50bb, #00d2ff);
        transform: translateY(-2px);
        box-shadow: 0 10px 20px rgba(157, 80, 187, 0.3);
    }
    .error-msg {
        background: rgba(255, 77, 77, 0.1);
        border: 1px solid #ff4d4d;
        color: #ff4d4d;
        padding: 12px;
        border-radius: 12px;
        margin-bottom: 20px;
        font-size: 0.9rem;
        text-align: center;
    }
</style>

<div class="auth-container">
    <div class="auth-card">
        <h2 class="auth-title">User Login</h2>
        <p style="color: rgba(255,255,255,0.5); font-size: 0.9rem; margin-bottom: 25px;">Access secured task framework</p>

        @if (!string.IsNullOrEmpty(Model.Message))
        {
            <div class="error-msg">
                ⚠️ @Model.Message
            </div>
        }

        <form method="post">
            <div class="auth-input-group">
                <label class="auth-label">Email Address</label>
                <input type="email" asp-for="Email" class="auth-field" required autocomplete="off" />
            </div>
            
            <div class="auth-input-group">
                <label class="auth-label">Password</label>
                <input type="password" asp-for="Password" class="auth-field" required />
            </div>

            <button type="submit" class="auth-btn">Authenticate Identity</button>
        </form>

        <p style="color: rgba(255,255,255,0.4); font-size: 0.85rem; text-align: center; margin-top: 25px;">
            Need a system profile? <a href="/Register" style="color: #00d2ff; text-decoration: none; font-weight: 600;">Sign Up</a>
        </p>
    </div>
</div>