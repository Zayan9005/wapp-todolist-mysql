<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - wapp</title>
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <style>
        header, .border-bottom, footer {
            border: none !important;
            box-shadow: none !important;
        }

        body {
            background-color: #0f0c29;
            margin: 0;
            padding: 0;
            min-height: 100vh;
            font-family: 'Segoe UI', sans-serif;
            color: #fff;
            display: block !important;
        }

        .navbar {
            display: flex;
            justify-content: center;
            padding: 20px 0;
            background: transparent;
            width: 100%;
            z-index: 10;
        }

        .navbar-nav {
            display: flex;
            list-style: none;
            margin: 0;
            padding: 0;
            gap: 20px;
            align-items: center;
        }

        .nav-link {
            color: rgba(255, 255, 255, 0.7) !important;
            text-decoration: none;
            font-weight: 600;
            font-size: 0.95rem;
            transition: color 0.3s ease;
        }

        .nav-link:hover {
            color: #00d2ff !important;
        }

        .text-danger-hover:hover {
            color: #ff4d4d !important;
        }

        .container {
            width: 100%;
            max-width: 1200px !important;
            margin: 0 auto;
            padding: 20px;
            box-sizing: border-box;
        }

        main {
            width: 100%;
            display: block;
        }

        .todo-layout-grid {
            display: grid;
            grid-template-columns: 380px 1fr;
            gap: 30px;
            margin-top: 20px;
            align-items: start;
        }

        .card {
            background: rgba(255, 255, 255, 0.05);
            border: 1px solid rgba(255, 255, 255, 0.1);
            border-radius: 12px;
            padding: 25px;
            margin-bottom: 20px;
            box-sizing: border-box;
        }

        .card h2 {
            margin-top: 0;
            color: #00d2ff;
        }

        form p {
            margin-bottom: 15px;
        }

        form label {
            color: #fff;
        }

        form input[type="text"],
        form input[type="email"],
        form input[type="password"],
        form input[type="date"] {
            width: 100%;
            padding: 10px;
            border-radius: 6px;
            border: 1px solid rgba(255, 255, 255, 0.2);
            background: rgba(0, 0, 0, 0.3);
            color: #fff;
            box-sizing: border-box;
        }

        form button[type="submit"] {
            background: #00d2ff;
            color: #0f0c29;
            border: none;
            padding: 12px 20px;
            font-weight: bold;
            border-radius: 6px;
            cursor: pointer;
            width: 100%;
        }

        .todo-card-container {
            display: grid;
            grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
            gap: 20px;
        }

        .todo-card {
            background: rgba(255, 255, 255, 0.03);
            border: 1px solid rgba(255, 255, 255, 0.1);
            border-left: 5px solid #2ecc71;
            padding: 20px;
            border-radius: 4px;
            box-sizing: border-box;
        }

        .todo-card.not-completed {
            border-left-color: #e74c3c;
        }

        .action-links {
            display: flex;
            flex-wrap: wrap;
            gap: 10px;
        }

        .todo-action-btn, .edit-btn {
            padding: 8px 14px;
            font-size: 0.85rem;
            border-radius: 4px;
            text-decoration: none;
            font-weight: 600;
            cursor: pointer;
            border: none;
            display: inline-block;
        }

        .complete-btn { background: #2ecc71; color: #fff; }
        .incomplete-btn { background: #f1c40f; color: #000; }
        .delete-btn { background: #e74c3c; color: #fff; }
        .edit-btn { background: #34495e; color: #fff; }

        .modal {
            display: none;
            position: fixed;
            z-index: 1000;
            left: 0;
            top: 0;
            width: 100%;
            height: 100%;
            background-color: rgba(0,0,0,0.75);
        }

        .modal-content {
            background-color: #1a163f;
            margin: 10% auto;
            padding: 30px;
            border: 1px solid rgba(255,255,255,0.2);
            width: 90%;
            max-width: 450px;
            border-radius: 12px;
            position: relative;
            color: #fff;
        }

        .close {
            position: absolute;
            right: 20px;
            top: 15px;
            color: #fff;
            font-size: 28px;
            cursor: pointer;
        }
    </style>
</head>
<body>
    <nav class="navbar">
        <ul class="navbar-nav">
            <li class="nav-item"><a class="nav-link" asp-page="/Index">Home</a></li>
            <li class="nav-item"><a class="nav-link" asp-page="/StudentInfo">My Info</a></li>
            <li class="nav-item"><a class="nav-link" asp-page="/CourseRegistration">Registration</a></li>
            <li class="nav-item"><a class="nav-link" asp-page="/Profile">Profile</a></li>

            @if (ViewContext.HttpContext.Session.GetInt32("UserId") != null)
            {
                <li class="nav-item">
                    <a class="nav-link" asp-page="/TodoList" style="color: #00d2ff !important;">My Tasks</a>
                </li>
                <li class="nav-item">
                    <span class="nav-link" style="color: rgba(255, 255, 255, 0.4) !important; font-weight: normal; cursor: default;">
                        👤 @ViewContext.HttpContext.Session.GetString("FullName")
                    </span>
                </li>
                <li class="nav-item">
                    <a class="nav-link text-danger-hover" asp-page="/Logout" style="color: #ff4d4d !important;">Logout</a>
                </li>
            }
            else
            {
                <li class="nav-item"><a class="nav-link" asp-page="/Login">Login</a></li>
                <li class="nav-item"><a class="nav-link" asp-page="/Register">Register</a></li>
            }
        </ul>
    </nav>

    <div class="container">
        <main role="main">
            @RenderBody()
        </main>
    </div>

    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>