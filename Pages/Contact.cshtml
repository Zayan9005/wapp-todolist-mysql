@page
@model wapp.Pages.ContactModel
@{
    ViewData["Title"] = "Contact Me";
    Layout = null;
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="stylesheet" href="~/css/site.css" />
    <style>
        :root {
            --accent: #00d2ff;
            --glass: rgba(255, 255, 255, 0.05);
        }

        body {
            background: radial-gradient(circle at center, #1e2a4a 0%, #0f0c29 100%);
            color: white;
            min-height: 100vh;
        }

        .contact-card {
            max-width: 700px;
            margin: 60px auto;
            background: var(--glass);
            backdrop-filter: blur(20px);
            border: 1px solid rgba(255, 255, 255, 0.1);
            border-radius: 30px;
            padding: 50px;
            box-shadow: 0 25px 50px rgba(0,0,0,0.5);
        }

        .form-group {
            position: relative;
            margin-bottom: 30px;
        }

        .form-input {
            width: 100%;
            padding: 15px;
            background: rgba(255, 255, 255, 0.02);
            border: 1px solid rgba(255, 255, 255, 0.1);
            border-radius: 12px;
            color: white;
            font-size: 1rem;
            transition: 0.3s;
        }

        .form-input:focus {
            outline: none;
            border-color: var(--accent);
            box-shadow: 0 0 15px rgba(0, 210, 255, 0.3);
            background: rgba(255, 255, 255, 0.07);
        }

        .submit-btn {
            background: linear-gradient(45deg, #00d2ff, #9d50bb);
            color: white;
            border: none;
            padding: 18px;
            border-radius: 12px;
            width: 100%;
            font-weight: bold;
            text-transform: uppercase;
            letter-spacing: 2px;
            cursor: pointer;
            transition: 0.4s;
        }

        .submit-btn:hover {
            transform: scale(1.02);
            box-shadow: 0 0 25px rgba(0, 210, 255, 0.5);
        }

        .success-overlay {
            background: rgba(0, 210, 255, 0.1);
            border-left: 5px solid var(--accent);
            padding: 20px;
            border-radius: 10px;
            margin-top: 30px;
            animation: slideIn 0.5s ease-out;
        }

        @@keyframes slideIn {
            from { opacity: 0; transform: translateX(-20px); }
            to { opacity: 1; transform: translateX(0); }
        }
    </style>
</head>
<body>

    <nav class="navbar">
        <a href="/">Home</a>
        <a href="/GradeCalculator">Grades</a>
        <a href="/FeedbackForm">Feedback</a>
        <a href="/Contact">Contact</a>
    </nav>

    <main class="container">
        <div class="contact-card">
            <h1 style="background: linear-gradient(to right, #00d2ff, #9d50bb); -webkit-background-clip: text; -webkit-text-fill-color: transparent; margin-bottom: 10px;">Get In Touch</h1>
            <p style="opacity: 0.6; margin-bottom: 40px;">Have a question? Send a message to the APU portal team.</p>

            <form method="post">
                <div class="form-group">
                    <label>Full Name</label>
                    <input type="text" asp-for="FullName" class="form-input" placeholder="Enter your name" required />
                </div>

                <div class="form-group">
                    <label>Email Address</label>
                    <input type="email" asp-for="EmailAddress" class="form-input" placeholder="name@example.com" required />
                </div>

                <div class="form-group">
                    <label>Subject</label>
                    <select asp-for="Subject" class="form-input" style="appearance: none;">
                        <option value="General Enquiry">General Enquiry</option>
                        <option value="Technical Support">Technical Support</option>
                        <option value="Academic Feedback">Academic Feedback</option>
                    </select>
                </div>

                <div class="form-group">
                    <label>Message</label>
                    <textarea asp-for="Message" class="form-input" rows="5" placeholder="How can we help you?" required></textarea>
                </div>

                <button type="submit" class="submit-btn">Send Secure Message</button>
            </form>

            @if (!string.IsNullOrEmpty(Model.StatusMessage))
            {
                <div class="success-overlay">
                    <h3 style="color: var(--accent); margin: 0;">✔ Message Dispatched</h3>
                    <p style="margin-top: 10px; opacity: 0.8;">@Model.StatusMessage</p>
                </div>
            }
        </div>
    </main>

    <footer class="page-footer">
        <p>&copy; 2026 APU Student Portal Service</p>
    </footer>
</body>
</html>